server:
  http_listen_port: 9080

positions:
  filename: /positions/positions.yaml

clients:
  - url: http://loki:3100/loki/api/v1/push

scrape_configs:
  # Docker コンテナログ（Docker SD で自動検出）
  - job_name: docker
    docker_sd_configs:
      - host: unix:///var/run/docker.sock
        refresh_interval: 30s
    relabel_configs:
      - source_labels: ['__meta_docker_container_name']
        regex: '/(.*)'
        target_label: 'service_name'
      - source_labels: ['__meta_docker_container_name']
        regex: '/(.*)'
        target_label: 'container_name'
      - action: replace
        replacement: docker
        target_label: job

  # ホストの syslog
  - job_name: syslog
    static_configs:
      - targets:
          - localhost
        labels:
          job: syslog
          service_name: syslog
          __path__: /var/log/syslog

  # ホストの auth.log
  - job_name: authlog
    static_configs:
      - targets:
          - localhost
        labels:
          job: authlog
          service_name: authlog
          __path__: /var/log/auth.log
