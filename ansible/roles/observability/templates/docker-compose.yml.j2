services:
  grafana:
    image: "{{ observability_grafana_image }}"
    container_name: grafana
    restart: unless-stopped
    ports:
      - "{{ observability_grafana_bind_address }}:{{ observability_grafana_port }}:3000"
    env_file:
      - grafana.env
    volumes:
      - grafana_data:/var/lib/grafana
      - ./grafana/datasources.yml:/etc/grafana/provisioning/datasources/datasources.yml:ro
      - ./grafana/dashboards.yml:/etc/grafana/provisioning/dashboards/dashboards.yml:ro
      - ./dashboards:/var/lib/grafana/dashboards:ro
    networks:
      - {{ traefik_network_name }}
      - observability-internal
    depends_on:
      prometheus:
        condition: service_healthy
      loki:
        condition: service_healthy
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.grafana.rule=Host(`{{ grafana_traefik_host }}`)"
      - "traefik.http.routers.grafana.entrypoints=websecure"
      - "traefik.http.routers.grafana.tls=true"
      - "traefik.http.routers.grafana.tls.certresolver=letsencrypt"
      - "traefik.http.services.grafana.loadbalancer.server.port=3000"
      - "traefik.docker.network={{ traefik_network_name }}"
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    mem_limit: {{ observability_grafana_mem_limit }}
    cpus: {{ observability_grafana_cpus }}
    pids_limit: 200
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  prometheus:
    image: "{{ observability_prometheus_image }}"
    container_name: prometheus
    restart: unless-stopped
    command:
      - "--config.file=/etc/prometheus/prometheus.yml"
      - "--storage.tsdb.path=/prometheus"
      - "--storage.tsdb.retention.time={{ observability_prometheus_retention }}"
    volumes:
      - ./prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus_data:/prometheus
    networks:
      - observability-internal
    healthcheck:
      test: ["CMD", "wget", "-q", "-O", "/dev/null", "http://localhost:9090/-/healthy"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 30s
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    mem_limit: {{ observability_prometheus_mem_limit }}
    cpus: {{ observability_prometheus_cpus }}
    pids_limit: 200
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  loki-init:
    image: "{{ observability_loki_image }}"
    container_name: loki-init
    user: root
    entrypoint: ["sh", "-c", "chown -R 10001:10001 /loki"]
    volumes:
      - ./loki-data:/loki
    restart: "no"

  loki:
    image: "{{ observability_loki_image }}"
    container_name: loki
    restart: unless-stopped
    command: -config.file=/etc/loki/loki.yml
    volumes:
      - ./loki.yml:/etc/loki/loki.yml:ro
      - ./loki-data:/loki
    networks:
      - observability-internal
    depends_on:
      loki-init:
        condition: service_completed_successfully
    healthcheck:
      test: ["CMD", "wget", "-q", "-O", "/dev/null", "http://localhost:3100/ready"]
      interval: 15s
      timeout: 5s
      retries: 5
      start_period: 30s
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    mem_limit: {{ observability_loki_mem_limit }}
    cpus: {{ observability_loki_cpus }}
    pids_limit: 200
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  node-exporter:
    image: "{{ observability_node_exporter_image }}"
    container_name: node-exporter
    restart: unless-stopped
    command:
      - "--path.rootfs=/host"
      - "--collector.filesystem.mount-points-exclude=^/(sys|proc|dev|host|etc)($$|/)"
    volumes:
      - /:/host:ro,rslave
    networks:
      - observability-internal
    pid: host
    read_only: true
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    mem_limit: {{ observability_node_exporter_mem_limit }}
    cpus: {{ observability_node_exporter_cpus }}
    pids_limit: 100
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  cadvisor:
    image: "{{ observability_cadvisor_image }}"
    container_name: cadvisor
    restart: unless-stopped
    volumes:
      - /:/rootfs:ro
      - /var/run:/var/run:ro
      - /sys:/sys:ro
      - /var/lib/docker/:/var/lib/docker:ro
      - /dev/disk/:/dev/disk:ro
    networks:
      - observability-internal
    privileged: false
    read_only: true
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - DAC_READ_SEARCH
      - SYS_PTRACE
    mem_limit: {{ observability_cadvisor_mem_limit }}
    cpus: {{ observability_cadvisor_cpus }}
    pids_limit: 200
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  promtail:
    image: "{{ observability_promtail_image }}"
    container_name: promtail
    restart: unless-stopped
    command: -config.file=/etc/promtail/promtail.yml
    volumes:
      - ./promtail.yml:/etc/promtail/promtail.yml:ro
      - /var/log:/var/log:ro
      - /var/lib/docker/containers:/var/lib/docker/containers:ro
      - promtail_positions:/positions
    networks:
      - observability-internal
    depends_on:
      loki:
        condition: service_healthy
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - DAC_READ_SEARCH
    mem_limit: {{ observability_promtail_mem_limit }}
    cpus: {{ observability_promtail_cpus }}
    pids_limit: 100
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

networks:
  {{ traefik_network_name }}:
    external: true
  observability-internal:
    driver: bridge

volumes:
  grafana_data:
  prometheus_data:
  promtail_positions:
