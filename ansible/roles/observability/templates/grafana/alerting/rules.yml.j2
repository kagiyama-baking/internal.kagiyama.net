apiVersion: 1

groups:
  - orgId: 1
    name: infrastructure
    folder: Alerting
    interval: 1m
    rules:
      # --- コンテナダウン検知 ---
      # absent_over_time で10分間メトリクスが不在のコンテナを検知
      # コンテナ停止時に cAdvisor がメトリクス報告を停止するため、
      # 値の大小ではなくメトリクスの不在で判定する
{% for container in observability_alert_containers %}
      - uid: container-down-{{ container }}
        title: "コンテナダウン: {{ container }}"
        condition: B
        data:
          - refId: A
            relativeTimeRange:
              from: 600
              to: 0
            datasourceUid: prometheus
            model:
              expr: >-
                absent_over_time(container_last_seen{name="{{ container }}"}[10m])
              instant: true
              refId: A
          - refId: B
            relativeTimeRange:
              from: 600
              to: 0
            datasourceUid: __expr__
            model:
              type: threshold
              expression: A
              conditions:
                - evaluator:
                    type: gt
                    params:
                      - 0
              refId: B
        for: 0s
        noDataState: OK
        execErrState: Alerting
        annotations:
          summary: "コンテナ {{ container }} が10分以上停止しています"
        labels:
          severity: critical
{% endfor %}

      # --- バックアップ失敗検知（エラーログ検出） ---
      # syslog 内の "Backup failed" ログを検出して即座に通知
      - uid: backup-failure
        title: バックアップ失敗
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 3600
              to: 0
            datasourceUid: loki
            model:
              expr: >-
                count_over_time({job="syslog"} |= "autorestic-backup" |= "Backup failed" [1h])
              refId: A
          - refId: B
            relativeTimeRange:
              from: 3600
              to: 0
            datasourceUid: __expr__
            model:
              type: reduce
              expression: A
              reducer: last
              refId: B
          - refId: C
            relativeTimeRange:
              from: 3600
              to: 0
            datasourceUid: __expr__
            model:
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: gt
                    params:
                      - 0
              refId: C
        for: 0s
        noDataState: OK
        execErrState: Alerting
        annotations:
          summary: "autorestic バックアップが失敗しました。syslog を確認してください。"
        labels:
          severity: critical

      # --- バックアップ未実行検知（成功ログの不在） ---
      # 26時間以内に成功ログがなければ発火（3:00 UTC 実行に2時間のバッファ）
      - uid: backup-missing
        title: バックアップ未実行
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: {{ observability_alert_backup_missing_hours * 3600 }}
              to: 0
            datasourceUid: loki
            model:
              expr: >-
                count_over_time({job="syslog"} |= "autorestic-backup" |= "Backup completed successfully" [{{ observability_alert_backup_missing_hours }}h])
              refId: A
          - refId: B
            relativeTimeRange:
              from: {{ observability_alert_backup_missing_hours * 3600 }}
              to: 0
            datasourceUid: __expr__
            model:
              type: reduce
              expression: A
              reducer: last
              refId: B
          - refId: C
            relativeTimeRange:
              from: {{ observability_alert_backup_missing_hours * 3600 }}
              to: 0
            datasourceUid: __expr__
            model:
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: lt
                    params:
                      - 1
              refId: C
        for: 0s
        noDataState: OK
        execErrState: Alerting
        annotations:
          summary: "過去{{ observability_alert_backup_missing_hours }}時間以内にバックアップ成功ログがありません。"
        labels:
          severity: warning

      # --- ディスク使用率検知 ---
      # Node Exporter のファイルシステムメトリクスで使用率90%超過を検知
      # tmpfs 等の仮想ファイルシステムは除外
      - uid: disk-usage-high
        title: ディスク使用率が90%超過
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 600
              to: 0
            datasourceUid: prometheus
            model:
              expr: >-
                100 - (
                  node_filesystem_avail_bytes{fstype!~"tmpfs|overlay|squashfs"} /
                  node_filesystem_size_bytes{fstype!~"tmpfs|overlay|squashfs"}
                ) * 100 > 90
              instant: true
              refId: A
          - refId: B
            relativeTimeRange:
              from: 600
              to: 0
            datasourceUid: __expr__
            model:
              type: reduce
              expression: A
              reducer: last
              refId: B
          - refId: C
            relativeTimeRange:
              from: 600
              to: 0
            datasourceUid: __expr__
            model:
              type: threshold
              expression: B
              conditions:
                - evaluator:
                    type: gt
                    params:
                      - 0
              refId: C
        for: 5m
        noDataState: NoData
        execErrState: Alerting
        annotations:
          summary: >-
            {% raw %}ディスク {{ $labels.mountpoint }} の使用率が90%を超えています（{{ $value }}%）{% endraw %}
        labels:
          severity: warning
