services:
  # Django REST API サーバー
  django-api:
    image: "{{ app_django_image }}"
    container_name: django
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      - "{{ app_install_dir }}/django-api/staticfiles:/django_api/staticfiles"
      - "{{ app_install_dir }}/django-api/db.sqlite3:/django_api/db.sqlite3"
    networks:
      - {{ traefik_network_name }}
      - app-internal
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.app-django.rule=Host(`{{ app_traefik_host }}`) && (PathPrefix(`/admin`) || PathPrefix(`/swagger`) || PathPrefix(`/schema`) || PathPrefix(`/redoc`) || PathPrefix(`/static`))"
      - "traefik.http.routers.app-django.entrypoints=websecure"
      - "traefik.http.routers.app-django.tls=true"
      - "traefik.http.routers.app-django.tls.certresolver=letsencrypt"
      - "traefik.http.routers.app-django.priority=200"
      - "traefik.http.services.app-django.loadbalancer.server.port=8000"
      - "traefik.docker.network={{ traefik_network_name }}"
    command: >
      sh -c "python manage.py migrate &&
             python manage.py collectstatic --noinput &&
             gunicorn django_api.wsgi:application --bind 0.0.0.0:8000 --workers {{ app_django_workers }} --timeout {{ app_django_timeout }} --access-logfile -"
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    mem_limit: {{ app_django_mem_limit }}
    cpus: {{ app_django_cpus }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  # フロントエンド（React SPA + nginx）
  frontend:
    image: "{{ app_frontend_image }}"
    container_name: frontend
    restart: unless-stopped
    volumes:
      - "{{ app_install_dir }}/frontend/banner.jpg:/usr/share/nginx/html/banner.jpg:ro"
    networks:
      - {{ traefik_network_name }}
      - app-internal
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.app-frontend.rule=Host(`{{ app_traefik_host }}`)"
      - "traefik.http.routers.app-frontend.entrypoints=websecure"
      - "traefik.http.routers.app-frontend.tls=true"
      - "traefik.http.routers.app-frontend.tls.certresolver=letsencrypt"
      - "traefik.http.routers.app-frontend.priority=100"
      - "traefik.http.services.app-frontend.loadbalancer.server.port=80"
      - "traefik.docker.network={{ traefik_network_name }}"
    depends_on:
      - django-api
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - SETGID
      - SETUID
    mem_limit: {{ app_frontend_mem_limit }}
    cpus: {{ app_frontend_cpus }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

networks:
  {{ traefik_network_name }}:
    external: true
  app-internal:
    driver: bridge
    internal: true
