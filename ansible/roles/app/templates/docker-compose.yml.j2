services:
  # Django REST API サーバー
  django-api:
    image: "{{ app_django_image }}"
    container_name: django-api
    hostname: django-api
    restart: unless-stopped
    env_file:
      - .env
    volumes:
      - "{{ app_install_dir }}/django-api/staticfiles:/django_api/staticfiles"
      - "{{ app_install_dir }}/django-api/media:/django_api/media"
    networks:
      - app-internal
    depends_on:
      app-database:
        condition: service_healthy
      redis:
        condition: service_healthy
    command: >
      sh -c "python manage.py migrate &&
             python manage.py collectstatic --noinput &&
             gunicorn django_api.wsgi:application --bind 0.0.0.0:8000 --workers {{ app_django_workers }} --timeout {{ app_django_timeout }} --access-logfile -"
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    mem_limit: {{ app_django_mem_limit }}
    cpus: {{ app_django_cpus }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  # Celery ワーカー（バックグラウンドタスク実行）
  celery-worker:
    image: "{{ app_django_image }}"
    container_name: celery-worker
    hostname: celery-worker
    restart: unless-stopped
    env_file:
      - .env
    networks:
      - app-internal
    depends_on:
      app-database:
        condition: service_healthy
      redis:
        condition: service_healthy
    command: celery -A django_api worker -l info --concurrency={{ app_celery_worker_concurrency }}
    healthcheck:
      test: ["CMD-SHELL", "celery -A django_api inspect ping"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    mem_limit: {{ app_celery_worker_mem_limit }}
    cpus: {{ app_celery_worker_cpus }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  # Celery Beat（定期タスクスケジューラ）
  celery-beat:
    image: "{{ app_django_image }}"
    container_name: celery-beat
    hostname: celery-beat
    restart: unless-stopped
    env_file:
      - .env
    networks:
      - app-internal
    depends_on:
      app-database:
        condition: service_healthy
      redis:
        condition: service_healthy
    command: celery -A django_api beat -l info --scheduler django_celery_beat.schedulers:DatabaseScheduler
    # beat は worker ではないため `celery inspect ping` (broadcast) に応答せず timeout する。
    # プロセス生存確認で代替。CMD 形式 (exec) にしてシェル経由の自己マッチを避ける。
    healthcheck:
      test: ["CMD", "pgrep", "-f", "celery -A django_api beat"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    mem_limit: {{ app_celery_beat_mem_limit }}
    cpus: {{ app_celery_beat_cpus }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  # Redis（Celery ブローカー）
  redis:
    image: "{{ app_redis_image }}"
    container_name: redis
    hostname: redis
    restart: unless-stopped
    networks:
      - app-internal
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 10s
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - SETGID
      - SETUID
    mem_limit: {{ app_redis_mem_limit }}
    cpus: {{ app_redis_cpus }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  # PostgreSQL データベース（pgvector 対応）
  app-database:
    image: "{{ app_db_image }}"
    container_name: app-database
    hostname: app-database
    restart: unless-stopped
    environment:
      POSTGRES_PASSWORD: "{{ app_vault_db_password }}"
      POSTGRES_USER: "{{ app_db_username }}"
      POSTGRES_DB: "{{ app_db_database_name }}"
      POSTGRES_INITDB_ARGS: "--data-checksums"
    volumes:
      - "{{ app_db_data_location }}:/var/lib/postgresql/data"
    networks:
      - app-internal
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -d {{ app_db_database_name }} -U {{ app_db_username }}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - CHOWN
      - DAC_OVERRIDE
      - FOWNER
      - SETGID
      - SETUID
    mem_limit: {{ app_db_mem_limit }}
    cpus: {{ app_db_cpus }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

  # フロントエンド（React SPA + nginx）
  frontend:
    image: "{{ app_frontend_image }}"
    container_name: frontend
    hostname: frontend
    restart: unless-stopped
    volumes:
      - "{{ app_install_dir }}/frontend/nginx.conf:/etc/nginx/conf.d/default.conf:ro"
    networks:
      - {{ traefik_network_name }}
      - app-internal
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.app.rule=Host(`{{ app_traefik_host }}`)"
      - "traefik.http.routers.app.entrypoints=websecure"
      - "traefik.http.routers.app.tls=true"
      - "traefik.http.routers.app.tls.certresolver=letsencrypt"
      - "traefik.http.services.app.loadbalancer.server.port=80"
      - "traefik.docker.network={{ traefik_network_name }}"
    depends_on:
      - django-api
    tmpfs:
      - /var/cache/nginx:uid=101,gid=101
      - /tmp:uid=101,gid=101
      - /run:uid=101,gid=101
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    mem_limit: {{ app_frontend_mem_limit }}
    cpus: {{ app_frontend_cpus }}
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

networks:
  {{ traefik_network_name }}:
    external: true
  app-internal:
    driver: bridge
