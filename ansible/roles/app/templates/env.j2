# Django API 環境変数（Ansible管理）
SECRET_KEY={{ app_vault_django_secret_key }}
DEBUG=False
ALLOWED_HOSTS={{ app_traefik_host }}
CSRF_TRUSTED_ORIGINS=https://{{ app_traefik_host }}
ENCRYPTION_KEY={{ app_vault_encryption_key }}

# データベース設定（PostgreSQL）
DB_ENGINE=django.db.backends.postgresql
DB_NAME={{ app_db_database_name }}
DB_USER={{ app_db_username }}
DB_PASSWORD={{ app_vault_db_password }}
DB_HOST=app-database
DB_PORT=5432

# Celery 設定（Redis ブローカー）
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# TTS サービス設定（Docker内部通信）
TTS_SERVICE_URL={{ app_sbv2_service_url }}
TTS_TIMEOUT=120

# LiteLLM Proxy（LLMゲートウェイ）
LITELLM_PROXY_URL={{ app_litellm_proxy_url }}
LITELLM_MASTER_KEY={{ app_vault_litellm_master_key }}

# Langfuse LLMOps（トレーシング・プロンプト管理）
LANGFUSE_SECRET_KEY={{ app_vault_langfuse_secret_key }}
LANGFUSE_PUBLIC_KEY={{ app_vault_langfuse_public_key }}
LANGFUSE_BASE_URL={{ app_langfuse_base_url }}
LANGFUSE_TRACING_ENVIRONMENT={{ app_langfuse_tracing_environment }}

