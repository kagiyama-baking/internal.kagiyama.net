# LangFuse v3 環境変数（Ansible管理）

# ===== セキュリティ =====
NEXTAUTH_SECRET={{ langfuse_vault_nextauth_secret }}
SALT={{ langfuse_vault_salt }}
ENCRYPTION_KEY={{ langfuse_vault_encryption_key }}

# ===== アプリケーション =====
NEXTAUTH_URL={{ langfuse_nextauth_url }}
HOSTNAME=0.0.0.0
PORT={{ langfuse_web_port }}

# ===== PostgreSQL =====
DATABASE_URL=postgresql://{{ langfuse_db_username }}:{{ langfuse_vault_db_password }}@langfuse-database:5432/{{ langfuse_db_database_name }}
DIRECT_URL=postgresql://{{ langfuse_db_username }}:{{ langfuse_vault_db_password }}@langfuse-database:5432/{{ langfuse_db_database_name }}

# ===== ClickHouse =====
CLICKHOUSE_MIGRATION_URL=clickhouse://langfuse-clickhouse:9000/{{ langfuse_clickhouse_database }}
CLICKHOUSE_URL=http://langfuse-clickhouse:8123
CLICKHOUSE_USER={{ langfuse_clickhouse_user }}
CLICKHOUSE_PASSWORD={{ langfuse_vault_clickhouse_password }}
CLICKHOUSE_CLUSTER_ENABLED=false

# ===== Redis =====
REDIS_CONNECTION_STRING=redis://:{{ langfuse_vault_redis_password }}@langfuse-redis:6379

# ===== S3 / MinIO =====
LANGFUSE_S3_EVENT_UPLOAD_BUCKET={{ langfuse_s3_event_bucket }}
LANGFUSE_S3_MEDIA_UPLOAD_BUCKET={{ langfuse_s3_media_bucket }}
LANGFUSE_S3_BATCH_EXPORT_BUCKET={{ langfuse_s3_export_bucket }}
LANGFUSE_S3_ENDPOINT={{ langfuse_s3_endpoint }}
LANGFUSE_S3_ACCESS_KEY_ID={{ langfuse_vault_minio_root_user }}
LANGFUSE_S3_SECRET_ACCESS_KEY={{ langfuse_vault_minio_root_password }}
LANGFUSE_S3_REGION={{ langfuse_s3_region }}
LANGFUSE_S3_FORCE_PATH_STYLE={{ langfuse_s3_force_path_style }}

# ===== OTLP =====
LANGFUSE_ENABLE_OTEL_ENDPOINT=true
