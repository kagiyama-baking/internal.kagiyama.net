services:
  portainer:
    image: "{{ portainer_image }}"
    container_name: portainer
    restart: unless-stopped
    ports:
      - "{{ portainer_bind_address }}:{{ portainer_https_port }}:9443"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - portainer_data:/data
    networks:
      - {{ traefik_network_name }}
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.portainer.rule=Host(`{{ portainer_traefik_host }}`)"
      - "traefik.http.routers.portainer.entrypoints=web"
      # TODO: HTTPS エントリポイント追加後に entrypoints=websecure に変更する
      - "traefik.http.services.portainer.loadbalancer.server.port=9000"
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    mem_limit: 256m
    cpus: 1.0
    pids_limit: 200
    logging:
      driver: "json-file"
      options:
        max-size: "10m"
        max-file: "3"

networks:
  {{ traefik_network_name }}:
    external: true

volumes:
  portainer_data:
