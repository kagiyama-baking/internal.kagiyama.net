{
    "editor.fontSize": 14,
    "editor.tabSize": 4,
    "editor.formatOnSave": true,
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "prettier.singleQuote": true,
    "prettier.tabWidth": 4,
    "prettier.useTabs": false,
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        }
    },
    "black-formatter.args": ["--line-length=88", "--skip-string-normalization"],
    "isort.args": ["--profile=black"],
    "python.testing.pytestEnabled": true,
    "python.testing.unittestEnabled": false,
    "python.testing.pytestArgs": ["django_api"],
    "python.testing.autoTestDiscoverOnSaveEnabled": true,
    "python.testing.cwd": "${workspaceFolder}/django_api",
    "python.envFile": "${workspaceFolder}/django_api/.env",
    "workbench.colorCustomizations": {
        // タイトルバー
        "titleBar.activeBackground": "#2dddda",
        "titleBar.activeForeground": "#4d4d4d",
        "titleBar.inactiveBackground": "#2dddda",
        "titleBar.inactiveForeground": "#b1b1b8",
        "titleBar.border": "#2dddda",
        // アクティビティバー
        "activityBar.background": "#2dddda",
        "activityBar.foreground": "#4d4d4d",
        "activityBar.inactiveForeground": "#4d4d4d",
        "activityBar.border": "#2dddda",
        // アクティビティバーのバッジ
        "activityBarBadge.background": "#3a3a40",
        "activityBarBadge.foreground": "#ffffff",
        "tab.activeBorder": "#00e1ff",
        "tab.activeBorderTop": "#1f1f1f",
        "tab.activeBackground": "#1f1f1f"
    },
    "makefile.configureOnOpen": false
}
